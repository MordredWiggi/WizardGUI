<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12 (API 31)+ backup / device-transfer rules.
     We exclude everything: saved games and paused state are local-only and
     contain no data we want migrated to a new device automatically. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
