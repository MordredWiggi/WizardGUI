<?xml version="1.0" encoding="utf-8"?>
<!-- Legacy auto-backup rules (Android 6 – 11). Same intent as
     data_extraction_rules.xml: exclude everything. -->
<full-backup-content>
    <exclude domain="root" />
    <exclude domain="file" />
    <exclude domain="database" />
    <exclude domain="sharedpref" />
    <exclude domain="external" />
</full-backup-content>
